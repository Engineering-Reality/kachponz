# Copy to `.env.test` (gitignored). Isolated database for `npm run test` —
# never point this at the same DB as your dev `.env`. See db setup below.
#
# One-time setup:
#   sudo -u postgres psql -c "CREATE DATABASE amadeus_test OWNER amadeus;"
#   DATABASE_URL=postgres://amadeus:amadeus_local_dev@127.0.0.1:5432/amadeus_test npm run migrate:up
#
# Note (2026-07-14): a fresh `migrate:up` currently fails partway through
# because `agents`/`tools`/`companies` were created directly in the dev DB
# outside node-pg-migrate and are missing from migration history (see
# docs/task4-mcp-uipath-audit.md). Until that's backfilled into a migration,
# clone the schema from the real dev DB instead:
#   pg_dump -h 127.0.0.1 -U amadeus -d amadeus --schema-only --no-owner --no-privileges \
#     | psql -h 127.0.0.1 -U amadeus -d amadeus_test
DATABASE_URL=postgres://amadeus:amadeus_local_dev@127.0.0.1:5432/amadeus_test
