{
  "name": "amadeus-orchestrator",
  "version": "0.1.0",
  "description": "Amadeus Transaction State Tracker + A2A Orchestrator (on-prem, no-Python, CISO-aligned)",
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <23"
  },
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names SERVER,MCP-MGR --prefix-colors cyan,magenta \"tsx watch src/server.ts\" \"tsx watch scripts/mcpAutoManager.ts\"",
    "dev:server": "tsx watch src/server.ts",
    "mcp:manager": "tsx watch scripts/mcpAutoManager.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate:up": "node-pg-migrate up -m migrations -j ts --tsconfig tsconfig.migrate.json",
    "migrate:down": "node-pg-migrate down -m migrations -j ts --tsconfig tsconfig.migrate.json",
    "robot:register": "tsx scripts/registerRobot.ts",
    "user:register": "tsx scripts/registerUser.ts",
    "user:reset-password": "tsx scripts/resetUserPassword.ts",
    "agent:sandbox": "tsx scripts/agentSandbox.ts",
    "recipe:seed-danantara": "tsx scripts/seedDanantaraRecipe.ts",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@langchain/anthropic": "^1.5.1",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/openai": "^1.5.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "argon2": "^0.41.1",
    "dotenv": "^16.6.1",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "jose": "^6.2.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "concurrently": "^10.0.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
