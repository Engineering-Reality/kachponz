# =============================================================================
# Amadeus Transaction Tracker + Meta-Orchestrator — Environment Example
# =============================================================================
# Salin ke `.env` dan sesuaikan. JANGAN commit `.env` (sudah di .gitignore).

# ─── Runtime ─────────────────────────────────────────────────────────────
NODE_ENV=development
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=info

# ─── Database (WAJIB — on-prem PostgreSQL) ───────────────────────────────
DATABASE_URL=postgres://amadeus:amadeus_local_dev@127.0.0.1:5432/amadeus
PG_POOL_MAX=10
PG_STATEMENT_TIMEOUT_MS=15000

# ─── Auth signatures ─────────────────────────────────────────────────────
# Pepper opsional untuk HMAC signature layer finansial.
SIGNATURE_PEPPER=ganti-dengan-nilai-acak-panjang-min-16-char
SIGNATURE_MAX_SKEW_SEC=300
# Untuk verifikasi Bearer JWT (OAuth2 layer, opsional MVP).
OAUTH2_JWT_SECRET=ganti-dengan-nilai-acak-panjang-min-16-char

# ─── Agent LLM lama (opsional — dipakai runAgenticStep legacy) ──────────
# AGENT_LLM_URL=http://qwen-inference.internal:8000/v1

# ─── Feature flag: route LC/SKBDN/SBLC transaction tracking ─────────────
# Default false: `/transactions/*` tidak terdaftar (404 natural). GET
# /health tetap selalu aktif terlepas dari flag ini. Set true untuk
# menjalankan/menguji route transaksi secara lokal.
ENABLE_TRANSACTION_ROUTES=false

# =============================================================================
# EXECUTORS (Meta-Orchestrator Layer)
# =============================================================================

# ─── Qwen (LLM / VLM untuk agent doc_examined & lainnya) ─────────────────
# ⚠️  MODE 'cloud' = DashScope Alibaba. HANYA untuk dev/demo dengan data
#     sintetis. Untuk production nasabah asli, WAJIB switch ke 'on_prem'.
#     Lihat komentar di src/orchestrator/executors/qwenClient.ts.
QWEN_MODE=cloud
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=sk-your-dashscope-api-key
QWEN_VL_MODEL=qwen-vl-max
QWEN_LLM_MODEL=qwen-plus
QWEN_TIMEOUT_MS=60000

# Untuk production (Qwen on-prem via Ollama/vLLM), ganti jadi:
# QWEN_MODE=on_prem
# QWEN_BASE_URL=http://qwen-inference.internal:8000/v1
# QWEN_API_KEY= (kosongkan bila server on-prem tidak butuh auth)
# QWEN_VL_MODEL=Qwen2.5-VL-7B-Instruct
# QWEN_LLM_MODEL=Qwen2.5-32B-Instruct

# ─── UiPath Automation Cloud ─────────────────────────────────────────────
UIPATH_BASE_URL=https://cloud.uipath.com
UIPATH_ORG=your-org-slug
UIPATH_TENANT=your-tenant-slug
UIPATH_CLIENT_ID=your-external-app-client-id
UIPATH_CLIENT_SECRET=your-external-app-client-secret
UIPATH_SCOPES=OR.Jobs OR.Robots.Read OR.Execution
UIPATH_FOLDER_ID=0
# Peta step→releaseKey UiPath process. Format:
#   "step[:type]=releaseKey;step2=releaseKey2"
UIPATH_RELEASE_MAP=mt_converted:import_lc=REPLACE_KEY;swift_released=REPLACE_KEY;settled=REPLACE_KEY

# ─── Power Automate Desktop ──────────────────────────────────────────────
# Mode: 'power_automate_http' | 'custom_bridge' | 'queued_only'
# Default 'queued_only' aman — hanya catat intent, operator manual jalankan.
PAD_DISPATCH_MODE=queued_only
# Bila mode HTTP, isi URL trigger flow (Power Automate cloud atau custom bridge).
# PAD_DISPATCH_URL=https://prod-01.westus.logic.azure.com/workflows/xxx/triggers/manual/paths/invoke
# Header auth opsional (mis. "X-Trigger-Key" atau "Authorization").
# PAD_DISPATCH_AUTH_HEADER=X-Trigger-Key
# PAD_DISPATCH_AUTH_VALUE=your-secret-value

# ─── Executor router preferences (opsional) ──────────────────────────────
# Override default router. Format:
#   "step[:type]=executor_id[,fallback_id];step2=executor_id"
# Bila tidak di-set, router otomatis pilih costUnit terkecil.
# Contoh: paksa step ee_ntf_created dieksekusi oleh PAD, bukan UiPath:
# EXECUTOR_PREFERENCES=ee_ntf_created=executor.pad.ee_create
