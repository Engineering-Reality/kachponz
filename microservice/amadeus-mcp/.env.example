PORT=10002
AMADEUS_API_BASE=http://127.0.0.1:8080
AMADEUS_ROBOT_KEY=<generated by transaction_tracker/scripts/registerRobot.ts>
# Only needed if transaction_tracker's SIGNATURE_PEPPER is set — must match it exactly,
# or financial-step HMAC signatures will never verify server-side.
AMADEUS_SIGNATURE_PEPPER=<must match transaction_tracker's SIGNATURE_PEPPER, leave unset if tracker doesn't set one>
